# Authentification (NextAuth)
# En local : http://localhost:3000
# En production : l'URL exacte de ton déploiement Vercel
NEXTAUTH_URL=http://localhost:3000

# Génération : openssl rand -base64 32
NEXTAUTH_SECRET=

# OAuth Google (console.cloud.google.com > APIs & Services > Credentials > OAuth client ID)
# Scopes utilisés par l'app : openid, email, profile, gmail.readonly, gmail.send
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase (Project Settings > API)
# NEXT_PUBLIC_SUPABASE_URL = "Project URL"
# SUPABASE_SERVICE_ROLE_KEY = clé "service_role" (jamais la clé "anon")
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Clé de chiffrement des tokens Gmail stockés en base (32 octets en hexadécimal)
# Génération : openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# IA — Claude (Anthropic), utilisé pour la classification, le résumé et la génération de brouillons
# Récupération : console.anthropic.com > Settings > API Keys
ANTHROPIC_API_KEY=
